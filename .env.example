# FREE/PREMIUM demo gate used only before real auth/subscriptions.
NEXT_PUBLIC_REAL_READER_DEMO_PLAN=free
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Keep browser for the local/free mode. Use elevenlabs only after configuring the key.
TTS_PROVIDER=browser

# Legacy placeholder kept for compatibility with older V1.1/V1.2 notes.
TTS_API_KEY=

# ElevenLabs server-side neural voice. Never expose these as NEXT_PUBLIC_*.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Stripe Checkout subscription.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# Supabase Auth/database placeholders.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Temporary staging bypass for testing premium-only server endpoints.
# Do not use as production authorization.
REAL_READER_PREMIUM_BYPASS_TOKEN=
REAL_READER_ALLOW_LOCAL_PREMIUM=false
