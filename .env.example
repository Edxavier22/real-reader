# FREE/PREMIUM demo gate used only before real auth/subscriptions.
NEXT_PUBLIC_REAL_READER_DEMO_PLAN=free
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=

# Primary TTS provider. Use elevenlabs when neural voice is configured.
SPEECH_PROVIDER=elevenlabs
TTS_PROVIDER=browser

# Legacy placeholder kept for compatibility with older V1.1/V1.2 notes.
TTS_API_KEY=

# ElevenLabs server-side neural voice. Never expose these as NEXT_PUBLIC_*.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_PROFESSOR_ID=
ELEVENLABS_VOICE_PROFESSORA_ID=
ELEVENLABS_VOICE_PODCAST_ID=
ELEVENLABS_VOICE_CALMO_ID=
ELEVENLABS_VOICE_MOTIVADOR_ID=
ELEVENLABS_VOICE_JORNALISTA_ID=
ELEVENLABS_VOICE_STORYTELLING_ID=
ELEVENLABS_VOICE_INFANTIL_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Future provider placeholders. Prepared, not active until adapters are implemented.
OPENAI_API_KEY=
AZURE_SPEECH_KEY=
GOOGLE_TTS_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Authorized personal voice. Only set after consent, validation and LGPD flow.
AUTHORIZED_VOICE_ID=

# Stripe Checkout subscription.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Supabase Auth/database.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# RC1 security note:
# Do not use public variables, local cookies or bypass tokens to mark users as Premium.
# Premium is resolved from Supabase session + Stripe subscription stored in the database.
